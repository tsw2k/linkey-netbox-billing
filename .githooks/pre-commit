#!/usr/bin/env bash
# Защита от случайного коммита секретов.
# Активация (один раз на клон):  git config core.hooksPath .githooks
set -euo pipefail

staged=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$staged" ] && exit 0

fail() { echo "❌ pre-commit: $1" >&2; echo "   Коммит остановлен. Уберите секрет из индекса (git restore --staged <файл>)." >&2; exit 1; }

# 1. Файлы-секреты по имени (кроме .env.example)
while IFS= read -r f; do
    case "$f" in
        .env.example) ;;
        .env|.env.*|*.pem|*.key|*.p12|*.pfx|secrets.*|credentials.*)
            fail "попытка закоммитить файл с секретами: $f" ;;
    esac
done <<< "$staged"

# 2. Похожие на реальные значения секреты в добавляемых строках.
#    Игнорируем плейсхолдеры (.env.example, changeme, <...>, и т.п.).
# Значение должно быть >=6 непробельных символов, чтобы не ловить аннотации
# типов вроде `token: str` (value "str," = 4 символа).
secret_re='(password|passwd|secret|token|api[_-]?key)[[:space:]]*[=:][[:space:]]*[^[:space:]]{6,}'
# Плейсхолдеры и заведомо не-секреты (аннотации типов, чтение из окружения).
placeholder_re='changeme|example|<[^>]+>|your[_-]|placeholder|xxxx|0123456789abcdef|=[[:space:]]*$|[=:][[:space:]]*(str|int|bool|float|dict|list|None|Optional)\b|os\.|getenv|environ|Field\('

# Файлы с заведомо disposable-значениями (шаблоны, локальная песочница) —
# content-скан пропускаем, но filename-блокировка выше на них всё равно действует.
scan_skip() {
    case "$1" in
        .env.example|deploy/sandbox/docker-compose.yml|deploy/sandbox/env.sandbox.example) return 0 ;;
        *) return 1 ;;
    esac
}

while IFS= read -r f; do
    scan_skip "$f" && continue
    [ -f "$f" ] || continue
    added=$(git diff --cached -U0 -- "$f" | grep '^+' | grep -v '^+++' || true)
    if echo "$added" | grep -iEq "$secret_re"; then
        if echo "$added" | grep -iE "$secret_re" | grep -ivEq "$placeholder_re"; then
            fail "в $f найдено похожее на реальный секрет значение"
        fi
    fi
done <<< "$staged"

exit 0
