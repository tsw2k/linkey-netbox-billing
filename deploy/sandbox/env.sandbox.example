# Готовый .env для тестирования против песочницы NetBox (deploy/sandbox/docker-compose.yml).
# Использование:  cp deploy/sandbox/env.sandbox.example .env   (из корня репозитория)
#
# BillManager здесь читается реальный (read-only пользователь!), а пишется всё
# в одноразовый локальный NetBox. NETBOX_PROD_MARKERS защищает от случайной
# подмены на прод-хост.

# --- BillManager: реальный, но read-only пользователь ---
BILLMGR_URL=https://billing.example.com:1500/billmgr
BILLMGR_USER=readonly_api_user
BILLMGR_PASSWORD=changeme
BILLMGR_VERIFY_TLS=true
# В песочнице НЕ пишем в биллинг — выданный IP только логируется.
BILLMGR_READONLY=true

# --- NetBox: локальная песочница из docker-compose ---
NETBOX_URL=http://localhost:8000
NETBOX_TOKEN=0123456789abcdef0123456789abcdef01234567
NETBOX_VERIFY_TLS=false

# Тег на всё созданное — потом легко вычистить фильтром по нему
NETBOX_SANDBOX_TAG=billmanager-sandbox
# Пул, из которого песочница выдаёт адреса. Создайте такой префикс в NetBox
# (или поправьте под свой) перед тестом провижининга.
NETBOX_IP_POOL_PREFIX=203.0.113.0/24

# Предохранитель: если случайно подставить прод-хост в NETBOX_URL — запись
# заблокируется. Впишите сюда подстроку вашего реального прод-NetBox.
NETBOX_PROD_MARKERS=netbox.prod.example.com
ALLOW_PROD=false

LOG_LEVEL=DEBUG
# Первый прогон лучше с DRY_RUN=true — проверить маппинг, ничего не записывая.
DRY_RUN=false
