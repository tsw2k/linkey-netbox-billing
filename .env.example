# --- BillManager (ISPsystem) ---
# Базовый URL панели, обычно с портом 1500 и путём /billmgr
BILLMGR_URL=https://billing.example.com:1500/billmgr
# Прямая авторизация admin-пользователя (authinfo=user:pass).
# Рекомендуется завести отдельного API-пользователя с ограниченными правами.
BILLMGR_USER=apiuser
BILLMGR_PASSWORD=changeme
# Проверять TLS-сертификат BillManager (false только для самоподписанных в тесте)
BILLMGR_VERIFY_TLS=true
# true = не писать в BillManager (выданный IP только логируется). Для тестов.
BILLMGR_READONLY=false
# Функция и поле, которыми выданный IP фиксируется на услуге. СВЕРЬТЕ С ПАНЕЛЬЮ!
BILLMGR_SET_IP_FUNC=service.edit
BILLMGR_IP_FIELD=ip

# --- NetBox ---
NETBOX_URL=https://netbox.example.com
NETBOX_TOKEN=0123456789abcdef0123456789abcdef01234567
NETBOX_VERIFY_TLS=true
# Тег на все созданные/изменённые объекты (для песочницы). Пусто = не тегировать.
NETBOX_SANDBOX_TAG=
# Префикс-пул, из которого NetBox выдаёт IP при подключении услуги (dedicated server).
# CIDR ("203.0.113.0/24") или числовой id префикса. Пусто = провижининг выключен.
NETBOX_IP_POOL_PREFIX=
# Предохранитель: подстроки прод-хостов NetBox (через запятую). Если NETBOX_URL
# содержит любую — запись блокируется, пока не задан ALLOW_PROD=true / --allow-prod.
NETBOX_PROD_MARKERS=
# Явно разрешить запись в прод (в проде поставьте true).
ALLOW_PROD=false

# --- Webhook-приёмник ---
# Секрет для проверки подписи входящих webhook от NetBox (X-Hook-Signature, HMAC-SHA512)
NETBOX_WEBHOOK_SECRET=changeme-webhook-secret
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# --- Общее ---
# Префикс custom field в NetBox, в которых храним связь с BillManager
LOG_LEVEL=INFO
DRY_RUN=false
