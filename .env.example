# --- BillManager (ISPsystem) ---
# Базовый URL панели, обычно с портом 1500 и путём /billmgr
BILLMGR_URL=https://billing.example.com:1500/billmgr
# Прямая авторизация admin-пользователя (authinfo=user:pass).
# Рекомендуется завести отдельного API-пользователя с ограниченными правами.
BILLMGR_USER=apiuser
BILLMGR_PASSWORD=changeme
# Проверять TLS-сертификат BillManager (false только для самоподписанных в тесте)
BILLMGR_VERIFY_TLS=true

# --- NetBox ---
NETBOX_URL=https://netbox.example.com
NETBOX_TOKEN=0123456789abcdef0123456789abcdef01234567
NETBOX_VERIFY_TLS=true

# --- Webhook-приёмник ---
# Секрет для проверки подписи входящих webhook от NetBox (X-Hook-Signature, HMAC-SHA512)
NETBOX_WEBHOOK_SECRET=changeme-webhook-secret
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# --- Общее ---
# Префикс custom field в NetBox, в которых храним связь с BillManager
LOG_LEVEL=INFO
DRY_RUN=false
